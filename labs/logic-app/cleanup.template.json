{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logicAppName": {
      "type": "string",
      "defaultValue": "A365-Workshop-Cleanup"
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus2"
    },
    "workshopDepartment": {
      "type": "string",
      "defaultValue": "workshop",
      "metadata": { "description": "Only users stamped with this department are eligible for deletion." }
    },
    "accountLifetimeMinutes": {
      "type": "int",
      "defaultValue": 480,
      "metadata": { "description": "Delete workshop accounts older than this (matches the 8h TAP lifetime)." }
    },
    "recurrenceHours": {
      "type": "int",
      "defaultValue": 1
    }
  },
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "workshopDepartment": {
              "type": "String",
              "defaultValue": "[parameters('workshopDepartment')]"
            },
            "accountLifetimeMinutes": {
              "type": "Int",
              "defaultValue": "[parameters('accountLifetimeMinutes')]"
            }
          },
          "triggers": {
            "Every_hour": {
              "type": "Recurrence",
              "recurrence": {
                "frequency": "Hour",
                "interval": "[parameters('recurrenceHours')]"
              }
            }
          },
          "actions": {
            "Get_workshop_users": {
              "type": "Http",
              "runAfter": {},
              "inputs": {
                "method": "GET",
                "uri": "https://graph.microsoft.com/v1.0/users",
                "queries": {
                  "$select": "id,userPrincipalName,createdDateTime,department",
                  "$filter": "@concat('department eq ''', parameters('workshopDepartment'), '''')",
                  "$top": "999"
                },
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://graph.microsoft.com"
                }
              }
            },
            "For_each_user": {
              "type": "Foreach",
              "runAfter": {
                "Get_workshop_users": [ "Succeeded" ]
              },
              "foreach": "@body('Get_workshop_users')?['value']",
              "actions": {
                "If_expired": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "less": [
                          "@ticks(items('For_each_user')?['createdDateTime'])",
                          "@ticks(addMinutes(utcNow(), mul(-1, parameters('accountLifetimeMinutes'))))"
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Delete_user": {
                      "type": "Http",
                      "inputs": {
                        "method": "DELETE",
                        "uri": "@concat('https://graph.microsoft.com/v1.0/users/', items('For_each_user')?['id'])",
                        "authentication": {
                          "type": "ManagedServiceIdentity",
                          "audience": "https://graph.microsoft.com"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {}
      }
    }
  ],
  "outputs": {
    "principalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('logicAppName')), '2019-05-01', 'Full').identity.principalId]"
    }
  }
}
